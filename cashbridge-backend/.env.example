# ==============================================================================
# CASHBRIDGE BACKEND ENVIRONMENT CONFIGURATION (PRODUCTION TEMPLATE)
# ==============================================================================

# Application general configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Security and Keys
JWT_ACCESS_SECRET=your_jwt_access_token_secret_min_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_min_32_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Supabase Postgres setup
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-public-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-highly-private-key

# MTN MoMo Subscriber Details (Sandbox / Live)
MTN_MOMO_API_BASE=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your-ocp-apim-subscription-key
MTN_MOMO_USER_ID=your-sandbox-provisioned-api-user-uuid
MTN_MOMO_API_KEY=your-sandbox-provisioned-api-key
MTN_MOMO_CALLBACK_URL=https://your-api-domain.com/api/v1/callbacks/momo

# Paystack Payment Gateway configuration
PAYSTACK_SECRET_KEY=sk_test_your_private_paystack_test_or_live_key
PAYSTACK_CALLBACK_URL=https://your-api-domain.com/api/v1/callbacks/paystack

# CORS Allow List
CLIENT_URL=http://localhost:5173
